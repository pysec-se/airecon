{
  "_meta": {
    "version": "3.0.0",
    "standard": "OWASP Web Top 10 (2021) + OWASP API Security Top 10 (2023)",
    "description": "Auto-classification rules for evidence entries. Each rule maps keywords and tags to an OWASP category with a base severity (1-5), negative exclusions, high-confidence indicators, remediation hints, and CWE references.",
    "severity_scale": {
      "5": "Critical — immediate exploitation, full compromise possible",
      "4": "High — significant impact, direct data/access loss",
      "3": "Medium — exploitable but requires conditions",
      "2": "Low — limited impact, information disclosure",
      "1": "Info — recon finding, no direct impact"
    }
  },
  "rules": [
    {
      "id": "A01:2021",
      "name": "Broken Access Control",
      "description": "Restrictions on authenticated users are not properly enforced. Attackers can act outside their intended permissions.",
      "base_severity": 4,
      "keywords": [
        "idor", "insecure direct object", "broken object level",
        "access control", "broken access", "missing access control",
        "unauthorized access", "unauthorized request", "unauthenticated access",
        "privilege escalat", "privilege escalation",
        "horizontal escalat", "vertical escalat",
        "path traversal", "directory traversal", "dot dot slash", "../", "..\\",
        "403 bypass", "401 bypass", "forbidden bypass", "access bypass",
        "missing authorization", "missing access check", "no authorization",
        "force browse", "forceful browsing", "forced browsing",
        "jwt none algorithm", "jwt alg none",
        "object reference", "mass assignment", "parameter binding",
        "unrestricted file access", "admin panel exposed", "admin panel accessible",
        "cors bypass", "cors misconfigur", "cors allow all origins",
        "open redirect", "unvalidated redirect",
        "api versioning bypass", "old api version",
        "graphql authorization", "graphql missing auth",
        "uuid enumeration", "predictable uuid",
        "http parameter pollution", "hpp attack",
        "referrer bypass", "referer check bypass",
        "method override", "x-http-method-override",
        "bola", "bfla", "broken function level authorization",
        "object property exposure", "excessive data exposure",
        "insecure api key", "api key no scope"
      ],
      "high_confidence_keywords": [
        "idor confirmed", "object reference bypass",
        "privilege escalation confirmed", "horizontal privilege",
        "403 bypassed", "access control bypass confirmed",
        "unauthorized data access", "another user data"
      ],
      "negative_keywords": [
        "access control implemented", "properly restricted",
        "access denied correctly", "correctly returns 403",
        "access control working", "not vulnerable to idor",
        "mitigated", "patched", "fixed", "protected"
      ],
      "tags": [
        "idor", "access", "privilege", "traversal", "bypass",
        "authorization", "mass_assignment", "cors", "bola", "bfla"
      ],
      "tools_hint": ["ffuf", "burpsuite", "feroxbuster", "nuclei", "arjun"],
      "cwe": ["CWE-22", "CWE-284", "CWE-285", "CWE-639", "CWE-862", "CWE-863"],
      "remediation": [
        "Enforce access control on every server-side resource — deny by default",
        "Implement object-level authorization checks in every API endpoint",
        "Log and alert access control failures",
        "Rate-limit API access to minimize brute-force impact",
        "Invalidate server-side session tokens after logout"
