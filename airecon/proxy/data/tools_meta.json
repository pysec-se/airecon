        "validator": {
            "replay": {
                "thresholds": {
                    "strict_with_runtime": 0.58,
                    "strict_no_runtime": 0.48,
                    "non_strict": 0.38
                },
                "score_weights": {
                    "request_logged": 0.16,
                    "response_logged": 0.16,
                    "target_bound": 0.18,
                    "payload_observed": 0.14,
                    "matching_finding": 0.12,
                    "artifact_bound": 0.09,
                    "runtime_http": 0.09,
                    "runtime_signal": 0.06,
                    "runtime_impact": 0.05,
                    "runtime_host_bound": 0.05,
                    "runtime_payload_bound": 0.05,
                    "no_runtime_text_bonus": 0.08
                },
                "gap_messages": {
                    "request_logged": "describe the exact replay request that was executed",
                    "response_logged": "describe the exploit response that was observed",
                    "payload_observed": "link the payload to the observed output",
                    "target_bound": "bind the PoC to the same target/endpoint as the finding",
                    "runtime_command_logged": "include the exact replay command that was executed",
                    "runtime_response_logged": "include runtime response details (status/body) for that replay",
                    "runtime_http": "include HTTP status evidence from runtime replay",
                    "runtime_signal": "include impact evidence from runtime replay",
                    "runtime_impact": "show runtime impact (data/error/access change), not only heartbeat output",
                    "runtime_host_bound": "use the same PoC host in runtime replay evidence",
                    "runtime_payload_bound": "use the same PoC payload in runtime replay evidence"
                }
            }
        },
        "causal_reasoning": {
            "support_threshold": 0.72,
