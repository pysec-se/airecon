    "output_parser_adaptive_hints": {
        "content_rules": [
            {
                "parser": "nmap",
                "contains_any": ["<?xml", "<nmaprun"]
            },
            {
                "parser": "nuclei",
                "contains_any": ["template-id"],
                "regex_any": ["\\[[^\\]]+\\]\\s*\\[(critical|high|medium|low|info)\\]"]
            },
            {
                "parser": "sqlmap",
                "command_contains_any": ["sqlmap"],
                "contains_any": ["appears injectable", "parameter '"]
            },
            {
                "parser": "whatweb",
                "command_contains_any": ["whatweb"],
                "contains_all": ["plugins", "summary"]
            }
        ],
        "count_rules": [
            {"parser": "naabu", "metric": "host_port_lines", "min_abs": 2, "min_ratio": 0.5},
            {"parser": "url_list", "metric": "url_lines", "min_abs": 2, "min_ratio": 0.6},
            {"parser": "subfinder", "metric": "subdomain_lines", "min_abs": 2, "min_ratio": 0.6},
            {"parser": "httpx", "metric": "json_lines", "min_abs": 2, "min_ratio": 0.5}
        ],
        "json_rules": [
            {
                "parser": "naabu",
                "regex_all": ["\"(?:host|ip)\"\\s*:\\s*\".+?\"", "\"port\"\\s*:\\s*\\d+"]
            },
            {
                "parser": "httpx",
                "regex_all": ["\"url\"\\s*:\\s*\".+?\"", "\"status\"\\s*:\\s*\\d{3}"]
            },
            {
                "parser": "nuclei",
                "regex_all": ["\"template-id\"\\s*:", "\"severity\"\\s*:"]
            }
        ],
